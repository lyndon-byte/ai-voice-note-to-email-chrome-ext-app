{
  "manifest_version": 3,
  "name": "AI Voice Note to Email",
  "version": "1.0.0",
  "description": "Record voice notes and send them via email",
  "permissions": [
    "activeTab", 
    "storage", 
    "offscreen",
    "sidePanel",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type" : "module"
  },
  "side_panel":{
    "default_path" : "index.html"
  },
  "action": {
    "default_title": "AI Voice Note to Email"
  }
}