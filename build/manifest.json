{
  "manifest_version": 3,
  "name": "Talking to Eleven - Voice Note To Email AI",
  "version": "1.0.0",
  "description": "Record voice notes and turn into structured and ready to send emails",
   "icons": {
    "128": "/talking-to-eleven-icon.png"
  },
  "permissions": [
    "activeTab", 
    "storage", 
    "offscreen",
    "sidePanel",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type" : "module"
  },
  "side_panel":{
    "default_path" : "index.html"
  },
  "action": {
    "default_title": "Talking to Eleven"
  }

}